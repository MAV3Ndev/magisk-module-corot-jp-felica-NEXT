#パッケージ名
execute.package.name=com.felicanetworks.mfw.a.boot

#実行クラス名
execute.class.name=.Applet

#実行部のエンドエンティティ証明書のパス
execute.signature.path=/assets/signature.txt

#中間ページURL
url.intermediate.page=https://ms.fnopf.jp/sm/middle

#アプリケーションID
application.id=0204

#アプリケーションバージョン
application.version=3.2.0

#プラットフォーム種別
platform.type=02

#許可証種別
permit.type=01

#許可証バージョン
permit.version=0001

#オフラインバージョン判定回数上限
offline.verup.eval.count.limit=1000

#オフラインバージョン判定期間上限
offline.verup.eval.term=259200

#シリアル番号数上限
rvction.serial.number.limit=200

#オフライン失効判定回数上限
rvction.limit=1000

#オフライン失効判定期間上限
rvction.term=259200

#最大実行可能コマンドデータ数
max.commanddata.count=5

#外部カード捕捉試行時間
command.rw.try.time=25

#外部カード捕捉試行時間(捕捉成功画面push用)
command.push.try.time=5

#バージョンアップ確認要求先URL
url.verup.confir.req=https://ms.fnopf.jp/ws/ex_version

#障害解析ログ送信先URL
url.prblm.analyze.log.send=https://ms.fnopf.jp/ws/trouble

#一次発行実施アプリのパッケージ名
format.felica.package.name=com.felicanetworks.mfs

#一次発行実施アプリのクラス名
format.felica.class.name=com.felicanetworks.mfs.MobileFeliCaSettings

#永続化領域フォーマットバージョン
perm.area.format.versionup=03

#通信量の最大値
conn.response.size=153600

#ポート番号の上限値
url.port.upperbound=65535

#ポート番号の下限値
url.port.lowerbound=0

#MFCパッケージ名
mfc.package.name=com.felicanetworks.mfc

#MFCパーミッション情報
mfc.permission=com.felicanetworks.mfc.permission.MFC_ACCESS
