<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="3dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.felicanetworks.mfm.main.view.widget.HorizontalLoadingView
        android:id="@+id/loadingView"
        android:background="@drawable/bg_loading_service_background"
        android:padding="6dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_alignLeft="@+id/foreground"
        android:layout_alignTop="@+id/foreground"
        android:layout_alignRight="@+id/foreground"
        android:layout_alignBottom="@+id/foreground"
        android:layout_alignStart="@+id/foreground"
        android:layout_alignEnd="@+id/foreground"/>
    <com.felicanetworks.mfm.main.view.widget.HoleGroup
        android:id="@+id/foreground"
        android:background="@drawable/bg_loading_service_foreground"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.felicanetworks.mfm.main.view.widget.HoleView
            android:id="@+id/imageHole"
            android:layout_width="90dp"
            android:layout_height="58dp"
            android:layout_margin="6dp"
            app:cornerRadius="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.felicanetworks.mfm.main.view.widget.HoleView
            android:id="@+id/label1Hole"
            android:layout_width="0dp"
            android:layout_height="14dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginRight="120dp"
            android:layout_marginBottom="6dp"
            app:layout_constraintBottom_toTopOf="@+id/label2Hole"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imageHole"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"/>
        <com.felicanetworks.mfm.main.view.widget.HoleView
            android:id="@+id/label2Hole"
            android:layout_width="0dp"
            android:layout_height="14dp"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="6dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/imageHole"
            app:layout_constraintTop_toBottomOf="@+id/label1Hole"
            app:layout_constraintVertical_chainStyle="packed"/>
    </com.felicanetworks.mfm.main.view.widget.HoleGroup>
</RelativeLayout>
