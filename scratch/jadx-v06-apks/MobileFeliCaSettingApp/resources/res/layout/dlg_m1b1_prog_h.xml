<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:minWidth="1000dp"
    style="?attr/DialogBkg">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="top"
                android:id="@+id/iv_dlg_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginLeft="12dp"/>
            <TextView
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@+id/tv_dlg_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="12dp"
                style="?attr/TextSub20"/>
        </LinearLayout>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginLeft="4dp"
            android:layout_marginTop="2dp"
            android:layout_marginRight="4dp"
            style="?attr/DialogDivider"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <ScrollView
            android:id="@+id/sv_dlg1"
            android:paddingLeft="14dp"
            android:paddingTop="2dp"
            android:paddingRight="10dp"
            android:paddingBottom="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?attr/ScrollViewStyleDialog">
            <LinearLayout
                android:gravity="left"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="?attr/TextSub16"
                    android:layout_gravity="top"
                    android:id="@+id/tv_dlg_msg1"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="2dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginRight="2dp">
                    <ProgressBar
                        android:id="@+id/pb_dlg_prog_bar"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressDrawable="?attr/ProgressDrawableMain"
                        android:layout_centerHorizontal="true"
                        style="?android:attr/progressBarStyleHorizontal"/>
                    <TextView
                        android:textAppearance="?attr/TextMain12"
                        android:gravity="top"
                        android:id="@+id/tv_dlg_prog_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:text="@+id/progress_percent"
                        android:layout_below="@+id/pb_dlg_prog_bar"
                        android:layout_alignParentLeft="true"/>
                </RelativeLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
