<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/bgcolor_white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:scrollbarStyle="outsideOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="240dp">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:gravity="center"
                        android:background="@drawable/frame_cardreader_servicename"
                        android:paddingLeft="26dp"
                        android:paddingRight="26dp"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp">
                        <TextView
                            android:textSize="16dp"
                            android:textStyle="normal"
                            android:textColor="@color/textcolor_white"
                            android:ellipsize="end"
                            android:id="@+id/tv_service_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="1"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ll_balance_item"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/iv_service_icon"
                            android:layout_width="42dp"
                            android:layout_height="42dp"/>
                        <TextView
                            android:textSize="64dp"
                            android:textStyle="bold"
                            android:textColor="@color/textColorBlue"
                            android:layout_gravity="bottom|right"
                            android:id="@+id/tv_balance_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="12dp"
                            android:text="@string/warning_value_nothing"
                            android:includeFontPadding="false"/>
                        <TextView
                            android:textSize="22dp"
                            android:textColor="@color/textColorBlue"
                            android:layout_gravity="bottom|left"
                            android:id="@+id/tv_balance_currency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="6dp"
                            android:text="@string/card_item_label_currency"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/ll_point_item"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/iv_point_label"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_cardreader_point"/>
                        <TextView
                            android:textSize="22dp"
                            android:textColor="@color/textcolor_secondary"
                            android:layout_gravity="bottom|left"
                            android:id="@+id/tv_point_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="6dp"
                            android:text="@string/warning_value_nothing"/>
                        <TextView
                            android:textSize="16dp"
                            android:textColor="@color/textcolor_secondary"
                            android:layout_gravity="bottom|left"
                            android:id="@+id/tv_point_currency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:text="@string/card_item_label_point"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:id="@+id/ll_fp_item"
                        android:layout_width="match_parent"
                        android:layout_height="54dp">
                        <Button
                            android:textSize="16dp"
                            android:textStyle="normal"
                            android:textColor="@color/textcolor_primary"
                            android:gravity="center"
                            android:id="@+id/b_select_fp_button"
                            android:background="@drawable/button_white_17"
                            android:paddingLeft="26dp"
                            android:paddingRight="8dp"
                            android:focusable="true"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:text="@string/button_text_select_felicapocket"
                            android:maxLines="1"
                            android:drawablePadding="8dp"
                            android:drawableEnd="@drawable/ic_arrow"
                            style="@style/TextAppearance.ButtonText"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_guide_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:layout_gravity="bottom"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <FrameLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/fl_button_background"
            android:background="@drawable/bg_card_white"
            android:padding="1dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="53dp">
            <Button
                android:textSize="18dp"
                android:textStyle="normal"
                android:textColor="@color/textcolor_white"
                android:gravity="center"
                android:id="@+id/b_select_recommend_button"
                android:background="@drawable/button_orange_fill_solid"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/button_text_use_mobile_felica"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:elevation="2dp"
                style="@style/TextAppearance.ButtonText"/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
