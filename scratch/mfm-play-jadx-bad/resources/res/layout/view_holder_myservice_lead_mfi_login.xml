<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/disable_card_frame"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/selectable"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:gravity="left"
            android:paddingLeft="@dimen/padding_for_indent_adjustment_at_lead_mfi_login"
            android:layout_width="@dimen/width_for_indent_adjustment_at_lead_mfi_login"
            android:layout_height="wrap_content"
            android:text="@string/card_item_text_setting_not_login"
            android:layout_centerInParent="true"
            style="@style/style_15_bold_white"/>
    </RelativeLayout>
</FrameLayout>
