<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:baselineAligned="false">
    <RelativeLayout
        android:orientation="vertical"
        android:layout_width="176dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="22dp">
        <TextView
            android:textSize="12dp"
            android:textColor="@color/color_6C6C6C"
            android:gravity="left"
            android:id="@+id/tv_history_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2019.06.28"/>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/tv_history_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="チャージ"
            android:layout_below="@+id/tv_history_date"
            android:layout_alignBaseline="@+id/tv_tmp"
            android:layout_alignParentBottom="true"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/black"
            android:gravity="end"
            android:id="@+id/tv_tmp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="14dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="22dp"
        android:layout_marginEnd="16dp">
        <TextView
            android:textSize="12dp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="end"
            android:id="@+id/tv_use_money_plus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="8dp"
            android:text="@string/card_item_text_usage_history_detail_screen_plus"
            android:layout_toLeftOf="@+id/tv_use_money"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:textSize="20dp"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="end"
            android:id="@+id/tv_use_money"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="6dp"
            android:text="20,000"
            android:layout_toLeftOf="@+id/tv_balance_currency"
            android:layout_alignBaseline="@+id/tv_balance_currency"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="12dp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="end"
            android:id="@+id/tv_balance_currency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/card_item_text_usage_history_detail_screen_balance_currency"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
