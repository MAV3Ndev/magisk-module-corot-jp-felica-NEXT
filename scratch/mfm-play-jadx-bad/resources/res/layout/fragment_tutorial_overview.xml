<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_0099C6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:scrollbarStyle="outsideOverlay"
        android:id="@+id/scrollView"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/overviewImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:layout_centerHorizontal="true"
                app:srcCompat="@drawable/tutorial_img_top"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_alignTop="@+id/overviewImage"
                android:layout_alignBottom="@+id/overviewImage"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true">
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="14dp"
                    android:textStyle="bold"
                    android:textColor="@color/textcolor_gray"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingTop="8dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:text="@string/tutorial_overview_title"
                    android:layout_weight="460"
                    android:lineSpacingExtra="8dp"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1780"/>
            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
    <androidx.appcompat.widget.AppCompatButton
        android:textSize="18dp"
        android:textColor="@color/text_collar_white"
        android:gravity="center"
        android:id="@+id/next"
        android:background="@drawable/button_orange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/button_text_next"
        android:layout_alignParentBottom="true"
        style="@style/TextAppearance.ButtonText"/>
</RelativeLayout>
