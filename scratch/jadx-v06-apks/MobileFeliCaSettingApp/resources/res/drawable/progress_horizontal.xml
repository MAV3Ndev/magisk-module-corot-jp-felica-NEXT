<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="1dp"/>
            <gradient
                android:startColor="@color/prg_bkg_s"
                android:endColor="@color/prg_bkg_e"
                android:angle="270"
                android:centerY="0.25"
                android:centerColor="@color/prg_bkg_c"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="1dp"/>
                <gradient
                    android:startColor="@color/prg_s"
                    android:endColor="@color/prg_e"
                    android:angle="270"
                    android:centerY="0.6"
                    android:centerColor="@color/prg_c"/>
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="1dp"/>
                <gradient
                    android:startColor="@color/prg_s"
                    android:endColor="@color/prg_e"
                    android:angle="270"
                    android:centerY="0.6"
                    android:centerColor="@color/prg_c"/>
            </shape>
        </clip>
    </item>
</layer-list>
