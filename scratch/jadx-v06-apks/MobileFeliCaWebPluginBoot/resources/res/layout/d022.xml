<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#ffe5e5e5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="vertical"
        android:focusable="true"
        android:nextFocusLeft="@+id/btn_cancel"
        android:nextFocusRight="@+id/btn_cancel"
        android:nextFocusUp="@+id/btn_cancel"
        android:nextFocusDown="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:gravity="center"
            android:id="@+id/anim_view"
            android:background="@anim/a003"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
        <TextView
            android:gravity="center_horizontal"
            android:id="@+id/tv_msg1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-105dp"
            android:text="@string/msg_D022"
            android:layout_below="@+id/anim_view"
            style="@style/TextDefault"/>
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/btn_cancel"
            android:maxLines="2"
            android:layout_weight="1"
            android:layout_below="@+id/tv_msg1"
            android:layout_centerHorizontal="true"
            style="?attr/DialogButton"/>
        <requestFocus/>
    </RelativeLayout>
</FrameLayout>
