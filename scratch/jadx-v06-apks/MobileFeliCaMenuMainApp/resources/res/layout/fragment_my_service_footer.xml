<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.felicanetworks.mfm.main.view.views.BannerLayout
        android:id="@+id/bv_banner_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">
        <androidx.viewpager.widget.ViewPager
            android:layout_gravity="center"
            android:id="@+id/vp_burner"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:focusable="true"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.felicanetworks.mfm.main.view.views.IndicatorLayout
            android:gravity="center"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/vg_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>
    </com.felicanetworks.mfm.main.view.views.BannerLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/ll_select_recommend"
        android:background="@drawable/bg_select_recommend"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp">
        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/top_additional_icon"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/button_text_add_myservice"
            style="@style/style_15_bold_white"/>
    </LinearLayout>
</LinearLayout>
