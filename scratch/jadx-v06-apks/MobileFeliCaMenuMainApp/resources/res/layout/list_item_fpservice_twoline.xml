<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:gravity="right"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/ll_line2_item"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="6dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="24dp">
        <LinearLayout
            android:gravity="bottom|right"
            android:layout_gravity="bottom|right"
            android:layout_width="match_parent"
            android:layout_height="38dp">
            <LinearLayout
                android:gravity="bottom|right"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textSize="24dp"
                    android:textColor="@color/textcolor_primary"
                    android:gravity="bottom|right"
                    android:id="@+id/tv_point_value"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginRight="5dp"
                    android:includeFontPadding="false"/>
                <TextView
                    android:textSize="18dp"
                    android:textColor="@color/textcolor_primary"
                    android:layout_gravity="bottom|left"
                    android:id="@+id/tv_point_unit"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:maxLines="1"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="bottom|right"
            android:id="@+id/ll_provider_name_area"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginBottom="28dp">
            <TextView
                android:textSize="11dp"
                android:textColor="@color/textcolor_secondary"
                android:ellipsize="end"
                android:gravity="bottom|right"
                android:id="@+id/tv_provider_name"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>
    </LinearLayout>
</merge>
