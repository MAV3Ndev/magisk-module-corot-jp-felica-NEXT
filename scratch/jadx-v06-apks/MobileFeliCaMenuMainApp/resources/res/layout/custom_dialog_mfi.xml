<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/ll_title_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:layout_marginBottom="24dp">
        <TextView
            android:textSize="18dp"
            android:textColor="@color/textcolor_primary"
            android:gravity="start|center_vertical"
            android:id="@+id/tv_title_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_mfi_cancel_pre"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="52dp"/>
            <TextView
                android:textSize="13dp"
                android:textColor="@color/textcolor_primary"
                android:layout_gravity="start|top"
                android:id="@+id/tv_body_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="2dp"/>
            <include
                android:id="@+id/pg_circle_progress"
                layout="@layout/circle_progress"/>
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/text_collar_primary"
                android:gravity="start"
                android:id="@+id/tv_body_text_14dp_primary"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginBottom="6dp"
                android:includeFontPadding="false"/>
            <TextView
                android:textSize="18dp"
                android:textStyle="normal"
                android:textColor="@color/color_accent"
                android:gravity="start"
                android:id="@+id/tv_body_text_18dp_accent"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginBottom="24dp"
                android:includeFontPadding="false"/>
            <TextView
                android:textSize="18dp"
                android:textStyle="normal"
                android:textColor="@color/textcolor_secondary"
                android:gravity="start"
                android:id="@+id/tv_body_text_18dp_secondary"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginBottom="24dp"
                android:includeFontPadding="false"/>
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/text_collar_primary"
                android:gravity="start"
                android:id="@+id/tv_body_text_14dp_secondary"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginBottom="6dp"
                android:includeFontPadding="false"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_mfi_cancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/textcolor_white"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/tv_mfi_cancel_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"/>
                <Button
                    android:textSize="16dp"
                    android:textColor="@color/textcolor_primary"
                    android:layout_gravity="bottom|center_horizontal"
                    android:id="@+id/bt_mfi_cancel"
                    android:background="@drawable/button_white"
                    android:paddingLeft="8dp"
                    android:paddingTop="2dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:minHeight="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:gravity="end"
        android:orientation="horizontal"
        android:id="@+id/ll_bottom_right_button"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="24dp"
        android:layout_marginRight="16dp">
        <TextView
            android:textSize="14dp"
            android:textColor="@color/textColorBlue"
            android:gravity="center"
            android:id="@+id/tv_negative_button"
            android:focusable="true"
            android:layout_width="75dp"
            android:layout_height="match_parent"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/textColorBlue"
            android:gravity="center"
            android:id="@+id/tv_positive_button"
            android:focusable="true"
            android:layout_width="75dp"
            android:layout_height="match_parent"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:layout_marginStart="8dp"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/textColorBlue"
            android:gravity="center"
            android:id="@+id/tv_positive_button_wrap"
            android:focusable="true"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
