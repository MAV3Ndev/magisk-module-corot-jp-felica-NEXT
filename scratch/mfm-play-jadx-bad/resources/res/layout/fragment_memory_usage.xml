<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/bgcolor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ScrollView
            android:id="@+id/sv_win_memusage"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_item_memusage"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </ScrollView>
        <TextView
            android:id="@+id/tv_seid_area_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_marginBottom="8dp"
            android:text="@string/text_seid"
            style="@style/style_15_bold_6C6C6C"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/ll_seid_area"
            android:background="@drawable/frame_memory_usage_seid_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:ellipsize="end"
                android:gravity="left"
                android:id="@+id/tv_seid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginTop="18dp"
                android:layout_marginRight="12dp"
                android:layout_marginBottom="18dp"
                android:maxLines="10"
                android:includeFontPadding="false"
                android:layout_weight="1"
                android:lineSpacingExtra="8dp"
                style="@style/style_13_bold_6C6C6C"/>
            <Button
                android:gravity="center"
                android:layout_gravity="top"
                android:id="@+id/seid_copy_button"
                android:background="@drawable/button_seid_copy"
                android:layout_width="56dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="12dp"
                android:text="@string/button_text_copy"
                android:textAllCaps="false"
                android:elevation="2dp"
                style="@style/style_12_bold_white"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
