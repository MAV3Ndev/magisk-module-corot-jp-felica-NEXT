<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/textcolor_secondary"
        android:id="@+id/tv_mem_sys"
        android:layout_width="match_parent"
        android:layout_height="20dp"/>
    <TextView
        android:textSize="16dp"
        android:textStyle="bold"
        android:textColor="@color/textcolor_primary"
        android:id="@+id/tv_mem_usage"
        android:layout_width="match_parent"
        android:layout_height="20dp"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ProgressBar
            android:id="@+id/pb_mem_prog"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:max="100"
            android:progressDrawable="@drawable/frame_memory_usage_horizontal"
            style="?android:attr/progressBarStyleHorizontal"/>
        <View
            android:background="@drawable/frame_memory_usage"
            android:layout_width="match_parent"
            android:layout_height="16dp"/>
    </FrameLayout>
</LinearLayout>
