<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_focused="true"
        android:state_checked="true"
        android:state_pressed="true"
        android:drawable="@drawable/btn_checkbox_on_focused_pressed"/>
    <item
        android:state_focused="true"
        android:state_checked="false"
        android:state_pressed="true"
        android:drawable="@drawable/btn_checkbox_off_focused_pressed"/>
    <item
        android:state_checked="true"
        android:state_pressed="true"
        android:drawable="@drawable/btn_checkbox_on_pressed"/>
    <item
        android:state_checked="false"
        android:state_pressed="true"
        android:drawable="@drawable/btn_checkbox_off_pressed"/>
    <item
        android:state_focused="true"
        android:state_checked="true"
        android:drawable="@drawable/btn_checkbox_on_focused"/>
    <item
        android:state_focused="true"
        android:state_checked="false"
        android:drawable="@drawable/btn_checkbox_off_focused"/>
    <item
        android:state_checked="false"
        android:drawable="@drawable/btn_checkbox_off_normal"/>
    <item
        android:state_checked="true"
        android:drawable="@drawable/btn_checkbox_on_normal"/>
</selector>
