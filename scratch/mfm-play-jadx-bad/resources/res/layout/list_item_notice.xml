<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_white"
        android:layout_width="match_parent"
        android:layout_height="132dp">
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingRight="8dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="96dp"
                android:layout_height="96dp">
                <ImageView
                    android:id="@+id/iv_service_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="start|top"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="13dp"
                    android:textColor="@color/textcolor_secondary"
                    android:ellipsize="end"
                    android:gravity="start|top"
                    android:id="@+id/tv_send_date"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:maxLines="1"/>
                <TextView
                    android:textSize="15dp"
                    android:textColor="@color/textcolor_primary"
                    android:ellipsize="end"
                    android:gravity="start|top"
                    android:id="@+id/tv_title_text"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:maxLines="5"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/iv_new_notice_image"
        android:paddingLeft="4dp"
        android:paddingTop="4dp"
        android:visibility="gone"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_news_tag"/>
</FrameLayout>
