<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/root"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="24dp"
            android:layout_weight="1"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="20dp">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">
                <TextView
                    android:textSize="24sp"
                    android:id="@+id/memory_clear_mfi_card_delete_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_memory_clear_title"
                    style="@style/TextAppearance.PreferenceTitle.SettingsLib"/>
            </ScrollView>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="48dp">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/memory_clear_mfi_card_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="@string/text_memory_clear_mfi_card_body"
                        android:contentDescription="@string/text_memory_clear_mfi_card_body"
                        style="@style/TextAppearance.PreferenceTitle.SettingsLib">
                        <requestFocus/>
                    </TextView>
                    <TextView
                        android:id="@+id/memory_clear_mfi_card_delete_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        style="@style/TextAppearance.PreferenceTitle.SettingsLib"/>
                    <TextView
                        android:id="@+id/text_memory_clear_mfi_card_body_information"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/text_memory_clear_mfi_card_information"
                        style="@style/TextAppearance.PreferenceTitle.SettingsLib"/>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="end|bottom"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:weightSum="4"
        android:layout_weight="3.5"
        android:layout_marginEnd="10dp">
        <Button
            android:id="@+id/memory_clear_mfi_card_delete_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_text_memory_clear_cancel"
            android:layout_weight="1"
            style="@style/Memory_Clear_Cancel_Button"/>
        <Button
            android:id="@+id/memory_clear_mfi_card_delete_next"
            android:background="@drawable/button_memory_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_text_memory_clear_mfi_card_delete"
            android:layout_weight="1"
            style="@style/Memory_Clear_Button"/>
    </LinearLayout>
</LinearLayout>
