<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1310302"
    android:versionName="31.3.2"
    android:compileSdkVersion="30"
    android:compileSdkVersionCodename="11"
    package="com.felicanetworks.mfc"
    platformBuildVersionCode="30"
    platformBuildVersionName="11">
    <uses-sdk
        android:minSdkVersion="30"
        android:targetSdkVersion="30"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.NFC"/>
    <uses-permission android:name="com.felicanetworks.mfc.permission.MFC_ACCESS"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <permission
        android:label="@string/permission_label"
        android:name="com.felicanetworks.mfc.permission.MFC_ACCESS"
        android:protectionLevel="normal"
        android:permissionGroup="com.felicanetworks.mfc.permission.group.FELICA_GROUP"
        android:description="@string/permission_desc"/>
    <permission-group
        android:label="@string/permission_group_label"
        android:name="com.felicanetworks.mfc.permission.group.FELICA_GROUP"
        android:description="@string/permission_group_desc"/>
    <uses-feature android:name="com.google.android.feature.PIXEL_EXPERIENCE"/>
    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:name="com.felicanetworks.mfc.MfcService"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:roundIcon="@mipmap/ic_launcher_round">
        <uses-library
            android:name="com.felicanetworks.felica"
            android:required="false"/>
        <service android:name="com.felicanetworks.mfc.FelicaAdapter">
            <intent-filter>
                <action android:name="com.felicanetworks.mfc.IFelica"/>
            </intent-filter>
        </service>
        <service android:name="com.felicanetworks.mfc.FSCAdapter">
            <intent-filter>
                <action android:name="com.felicanetworks.mfc.IFSC"/>
            </intent-filter>
        </service>
        <service android:name="com.felicanetworks.mfc.FalpService">
            <intent-filter>
                <action android:name="com.felicanetworks.mfc.IFalpService"/>
            </intent-filter>
        </service>
        <service android:name="com.felicanetworks.mfc.FalpSendIntentService">
            <intent-filter>
                <action android:name="com.felicanetworks.mfc.IFalpSendIntentService"/>
            </intent-filter>
        </service>
        <provider
            android:name="com.felicanetworks.mfc.provider.FelicaContentProvider"
            android:exported="true"
            android:authorities="com.felicanetworks.mfc.provider.FelicaContentProvider"/>
    </application>
</manifest>
