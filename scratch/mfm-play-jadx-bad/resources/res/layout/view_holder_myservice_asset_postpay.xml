<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/spendLabel1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_item_label_available_amt"
        android:lineSpacingExtra="1dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/style_14_bold_black"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/spendAsset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="1dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBaseline_toBaselineOf="@+id/spendUnit"
        app:layout_constraintEnd_toStartOf="@+id/spendUnit"
        style="@style/style_18_bold_black"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/spendUnit"
        android:paddingTop="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_item_label_currency"
        android:lineSpacingExtra="1dp"
        app:layout_constraintEnd_toEndOf="@+id/limitUnit"
        app:layout_constraintTop_toBottomOf="@+id/spendLabel1"
        style="@style/style_14_bold_black"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/limitLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_item_label_spend_limit"
        app:layout_constraintBaseline_toBaselineOf="@+id/limitAsset"
        app:layout_constraintStart_toStartOf="parent"
        style="@style/style_14_bold_6C6C6C"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/limitAsset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="1dp"
        android:layout_marginStart="6dp"
        app:layout_constraintStart_toEndOf="@+id/limitLabel"
        app:layout_constraintTop_toBottomOf="@+id/spendAsset"
        style="@style/style_15_medium_6C6C6C"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/limitUnit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_item_label_currency"
        android:lineSpacingExtra="1dp"
        android:layout_marginStart="4dp"
        app:layout_constraintBaseline_toBaselineOf="@+id/limitAsset"
        app:layout_constraintStart_toEndOf="@+id/limitAsset"
        style="@style/style_14_bold_6C6C6C"/>
</androidx.constraintlayout.widget.ConstraintLayout>
