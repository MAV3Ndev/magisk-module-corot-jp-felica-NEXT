<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Background" parent="">
    </style>
    <style name="Background.BkgColor" parent="@style/Background">
        <item name="android:background">@color/bgcolor</item>
    </style>
    <style name="Background.DetailsTitleBkg" parent="@style/Background">
        <item name="android:background">@color/details_title_bgcolor</item>
    </style>
    <style name="Background.DialogBkg" parent="@style/Background">
        <item name="android:windowBackground">@color/dialog_bgcolor</item>
        <item name="android:background">@color/dialog_bgcolor</item>
        <item name="android:tint">@color/dialog_bgcolor</item>
    </style>
    <style name="Button" parent="">
    </style>
    <style name="Button.DialogButton" parent="@style/Button">
        <item name="android:textSize">16dp</item>
        <item name="android:textColor">@color/button_textcolor</item>
        <item name="android:background">@drawable/btn_dialog</item>
    </style>
    <style name="CustomAlertDialog" parent="">
        <item name="bottomBright">@drawable/popup_bottom_bright</item>
        <item name="bottomDark">@drawable/popup_bottom_dark</item>
        <item name="bottomMedium">@drawable/popup_bottom_medium</item>
        <item name="centerBright">@drawable/popup_center_bright</item>
        <item name="centerDark">@drawable/popup_center_dark</item>
        <item name="centerMedium">@drawable/popup_center_medium</item>
        <item name="fullBright">@drawable/popup_full_bright</item>
        <item name="fullDark">@drawable/popup_full_dark</item>
        <item name="topBright">@drawable/popup_top_bright</item>
        <item name="topDark">@drawable/popup_top_dark</item>
    </style>
    <style name="ImageViewStyle" parent="">
    </style>
    <style name="ImageViewStyle.DialogDivider" parent="@style/ImageViewStyle">
        <item name="android:gravity">0x7</item>
        <item name="android:src">@drawable/p405</item>
        <item name="android:scaleType">1</item>
    </style>
    <style name="ScrollViewStyle" parent="">
    </style>
    <style name="ScrollViewStyle.Dialog" parent="@style/ScrollViewStyle">
        <item name="android:scrollbarThumbVertical">@drawable/p408</item>
    </style>
    <style name="ScrollViewStyle.Main" parent="@style/ScrollViewStyle">
        <item name="android:scrollbarThumbVertical">@drawable/p408</item>
        <item name="android:fadingEdge">0x0</item>
        <item name="android:isScrollContainer">true</item>
    </style>
    <style name="TextAppearance" parent="@android:style/TextAppearance">
    </style>
    <style name="TextAppearance.TextSub16" parent="@style/TextAppearance">
        <item name="android:textSize">16dp</item>
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="TextAppearance.TextSub20" parent="@style/TextAppearance">
        <item name="android:textSize">20dp</item>
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="TextDefault" parent="">
        <item name="android:textSize">16dp</item>
        <item name="android:typeface">1</item>
        <item name="android:textColor">#000000</item>
    </style>
    <style name="Theme" parent="@android:style/Theme.Translucent.NoTitleBar">
    </style>
    <style name="Theme.CustomAlert" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="Theme.Main" parent="@style/Theme">
        <item name="BkgColor">@style/Background.BkgColor</item>
        <item name="DetailsTitleBkg">@style/Background.DetailsTitleBkg</item>
        <item name="DialogBkg">@style/Background.DialogBkg</item>
        <item name="DialogButton">@style/Button.DialogButton</item>
        <item name="DialogDivider">@style/ImageViewStyle.DialogDivider</item>
        <item name="ScrollViewStyleDialog">@style/ScrollViewStyle.Dialog</item>
        <item name="ScrollViewStyleMain">@style/ScrollViewStyle.Main</item>
        <item name="TextSub16">@style/TextAppearance.TextSub16</item>
        <item name="TextSub20">@style/TextAppearance.TextSub20</item>
        <item name="alertDialogStyle">@style/CustomAlertDialog</item>
    </style>
</resources>
